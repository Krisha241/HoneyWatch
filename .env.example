# ──────────────────────────────────────────
# HoneyWatch — environment variables
# Copy this file to .env and fill in values
# NEVER commit .env to git
# ──────────────────────────────────────────

# Database
DB_USER=postgres
DB_PASSWORD=change_this_to_a_strong_password
DB_NAME=honeywatch
DB_HOST=db
DB_PORT=5432

# App
ENVIRONMENT=development

# Honeypot ports (must match docker-compose.yml)
SSH_TRAP_PORT=2222
HTTP_TRAP_PORT=8080
FTP_TRAP_PORT=2121
